# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Farfetch via Retailed (shoppable chat + inspo)
RETAILED_API_KEY=

# Google Shopping via SerpAPI (recommended quick multi-brand source)
SERPAPI_API_KEY=
# Optional: INSPO_PROVIDER=serpapi | retailed | revolve | auto
# Use revolve for local catalog only (web/data/products_cleaned.json or revolve_products.json); no SerpAPI key needed.
# Optional: REVOLVE_CATALOG_FILE=my-catalog.json  or  REVOLVE_CATALOG_PATH=C:\path\to\catalog.json
# INSPO_PROVIDER=auto

# Limit items to specific shop domains (comma-separated).
# Example: ALLOWED_SHOP_DOMAINS=revolve.com,ssense.com,net-a-porter.com
ALLOWED_SHOP_DOMAINS=

# Google Gemini — search understanding (optional; falls back to plain message if missing)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI — fallback catalog chat if RETAILED_API_KEY is not set
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
